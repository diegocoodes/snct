PORT=4101
HOST=0.0.0.0

# MySQL local
DATABASE_URL=mysql://root:12345@127.0.0.1:3306/snct
SNCT_DATABASE_POOL_SIZE=10

# Better Auth. Gere segredos independentes com pelo menos 32 caracteres.
# Em acesso externo, use a URL pública do frontend (ex.: http://IP:4100).
BETTER_AUTH_URL=http://localhost:4100
BETTER_AUTH_SECRET=
SNCT_RATE_LIMIT_SECRET=
# Lista versionada. Ex.: 1:<chave base64 de exatamente 32 bytes>
SNCT_DATA_ENCRYPTION_KEYS=
SNCT_TRUSTED_ORIGINS=http://localhost:4100,http://127.0.0.1:4100
SNCT_TRUST_PROXY=false

SNCT_ADMIN_EMAIL=
SNCT_ADMIN_PASSWORD=

SNCT_SMTP_HOST=
SNCT_SMTP_PORT=587
SNCT_SMTP_USER=
SNCT_SMTP_PASSWORD=
SNCT_EMAIL_FROM=

# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310

SNCT_PRIVACY_VERSION=2026-07-20
SNCT_ALLOWED_IMAGE_HOSTS=paulista.pe.gov.br,snct.paulista.pe.gov.br
APP_TIMEZONE=America/Recife
SNCT_UPLOADS_DIR=
