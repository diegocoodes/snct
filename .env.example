# PostgreSQL
DATABASE_URL=postgresql://snct:CHANGE_ME@127.0.0.1:5432/snct
DATABASE_SSL=disable
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SNCT_DATABASE_POOL_SIZE=10

# Better Auth. Gere segredos independentes com pelo menos 32 caracteres.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
SNCT_RATE_LIMIT_SECRET=
# Lista versionada. Ex.: 1:<chave base64 de exatamente 32 bytes>
SNCT_DATA_ENCRYPTION_KEYS=
SNCT_TRUSTED_ORIGINS=http://localhost:3000
SNCT_TRUST_PROXY=false

# Administrador inicial. A senha é convertida em Argon2id no primeiro acesso.
SNCT_ADMIN_EMAIL=
SNCT_ADMIN_PASSWORD=

# E-mail transacional obrigatório em produção.
SNCT_SMTP_HOST=
SNCT_SMTP_PORT=587
SNCT_SMTP_USER=
SNCT_SMTP_PASSWORD=
SNCT_EMAIL_FROM=

# Antivírus ClamAV obrigatório para uploads em produção.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# Privacidade e conteúdo administrável.
SNCT_PRIVACY_VERSION=2026-07-20
NEXT_PUBLIC_PRIVACY_CONTACT=
SNCT_ALLOWED_IMAGE_HOSTS=paulista.pe.gov.br,snct.paulista.pe.gov.br
