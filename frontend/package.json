{
  "name": "snct-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --import ./scripts/load-backend-env.mjs ./node_modules/next/dist/bin/next dev -H 0.0.0.0 -p 4100",
    "build": "node --import ./scripts/load-backend-env.mjs ./node_modules/next/dist/bin/next build",
    "start": "node --import ./scripts/load-backend-env.mjs ./node_modules/next/dist/bin/next start -H 0.0.0.0 -p 4100",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "security:check-env": "node --import ./scripts/load-backend-env.mjs ./scripts/verify-production-env.mjs",
    "security:audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@paper-design/shaders-react": "^0.0.77",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "file-type": "^22.0.1",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "mysql2": "^3.23.1",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
